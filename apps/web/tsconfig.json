{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@gold-shop/types": [
        "../../packages/types/src/index.ts"
      ],
      "@gold-shop/constants": [
        "../../packages/constants/src/index.ts"
      ],
      "@gold-shop/validation": [
        "../../packages/validation/src/index.ts"
      ],
      "@gold-shop/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@gold-shop/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@gold-shop/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
