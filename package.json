{
  "name": "gold-shop-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "pnpm --filter @gold-shop/api build && turbo run dev --parallel",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@gold-shop/web...",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:web": "pnpm --filter @gold-shop/web dev",
    "dev:api": "pnpm --filter @gold-shop/api start:dev",
    "vercel:run": "node scripts/vercel-token-cli.mjs",
    "vercel:whoami": "pnpm vercel:run -- whoami",
    "vercel:projects": "pnpm vercel:run -- projects ls",
    "vercel:deploy:web": "pnpm vercel:run -- deploy --prod"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
