NODE_ENV=development
APP_NAME=Gold Shop System
APP_TIMEZONE=Asia/Ho_Chi_Minh

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

SUPABASE_STORAGE_BUCKET_EXCEL_IMPORTS=excel-imports
APP_PROFILE_TABLES=users,profiles
APP_PROFILE_USER_ID_COLUMN=user_id
APP_PROFILE_ROLE_COLUMN=role
APP_PROFILE_STATUS_COLUMN=status
APP_PROFILE_EMPLOYEE_ID_COLUMN=employee_id
APP_PROFILE_FULL_NAME_COLUMN=full_name
APP_AUDIT_LOGS_TABLE=audit_logs
APP_IMPORT_SESSIONS_TABLE=import_sessions
APP_TRANSACTIONS_TABLE=transactions
APP_TRANSACTION_DATE_COLUMN=transaction_date
APP_TRANSACTION_AMOUNT_COLUMN=total_amount
APP_TRANSACTION_STATUS_COLUMN=status
APP_CASHBOOK_TABLE=cashbook_entries
APP_CASHBOOK_DATE_COLUMN=entry_date
APP_CASHBOOK_AMOUNT_COLUMN=amount
APP_CASHBOOK_TYPE_COLUMN=entry_type
APP_PRODUCTS_TABLE=products
APP_PRODUCTS_STOCK_COLUMN=current_stock
APP_PRODUCTS_REORDER_LEVEL_COLUMN=reorder_level
APP_INVENTORY_TABLE=inventory
APP_INVENTORY_QUANTITY_COLUMN=quantity

